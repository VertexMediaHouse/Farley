# ── dependencies ──────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── build output ──────────────────────────────────────
dist/
dist-ssr/
build/
out/

# ── local env files (NEVER commit secrets) ────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# ── logs ──────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Vite cache ────────────────────────────────────────
.vite/
vite.config.ts.timestamp-*

# ── TypeScript cache ──────────────────────────────────
*.tsbuildinfo

# ── testing ───────────────────────────────────────────
coverage/
.nyc_output/

# ── OS files ──────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── editor & IDE ──────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ── local / temp files ────────────────────────────────
*.local
*.tmp
*.temp
.cache/

# ── package manager locks (keep only one) ─────────────
# Uncomment the ones you do NOT use:
# yarn.lock
# pnpm-lock.yaml
